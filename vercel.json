{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "app/api/chat-agentic/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/chat-prompting/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/custom-agents/[id]/chat/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/doc-intelligence/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/ai-nexus/tender-extract/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/ai-nexus/tender-chat/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/ai-nexus/asset-chat/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/validate-prompt/route.ts": {
      "maxDuration": 60
    },
    "app/api/upload/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/data-backbone/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sample-data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/agents/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
