    {"code": "ASME-BPVC-SEC-VIII", "description": "ASME Unfired Pressure Vessels", "applicable_to": ["Heat Exchangers", "Deaerators", "Drums"], "mandatory": true},
    {"code": "IS-2062", "description": "Indian Standard Hot Rolled Steel", "applicable_to": ["Structural Steel"], "mandatory": true},
    {"code": "TEMA-R", "description": "Tubular Exchanger Manufacturers Association Class R", "applicable_to": ["Heat Exchangers"], "mandatory": false},
    {"code": "API-560", "description": "Fired Heaters for General Refinery Service", "applicable_to": ["Thermic Fluid Heaters"], "mandatory": true},
    {"code": "NFPA-85", "description": "Boiler and Combustion Systems Hazards Code", "applicable_to": ["All Combustion Equipment"], "mandatory": true},
    {"code": "IS-875", "description": "Code of Practice for Design Loads", "applicable_to": ["Structural Design"], "mandatory": true},
    {"code": "CPCB-2024", "description": "Central Pollution Control Board Emission Standards Phase III", "applicable_to": ["All Emission Sources"], "mandatory": true},
    {"code": "MOEF-2024", "description": "Ministry of Environment Norms", "applicable_to": ["All Environmental Equipment"], "mandatory": true}
