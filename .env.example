# Anthropic API key — set to enable live Claude responses
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model override (default: claude-opus-4-7)
ANTHROPIC_MODEL=claude-opus-4-7

# Path to the Thermax data files folder (relative to project root or absolute)
THERMAX_DATA_PATH=../SampLe Thermax Data Files
